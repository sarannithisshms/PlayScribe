{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "jsx": "react",
    "types": ["jest"],
    "typeRoots": ["./node_modules/@types", "./types"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
